{
  "name": "clido",
  "private": true,
  "bin": {
    "clido": "src/cli.ts"
  },
  "type": "module",
  "scripts": {
    "start": "node src/cli.ts",
    "prepare": "lefthook install",
    "lint": "oxlint -c oxlint.config.ts",
    "lint:fix": "oxlint -c oxlint.config.ts --fix",
    "lint:commit": "commitlint --from ${COMMITLINT_FROM:-HEAD~1} --to ${COMMITLINT_TO:-HEAD} --verbose",
    "lint:md": "markdownlint-cli2 --config .markdownlint-cli2.json",
    "format": "oxfmt -c oxfmt.config.ts",
    "format:check": "oxfmt -c oxfmt.config.ts --check",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cfonts": "^3.3.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/node": "^25.9.3",
    "eslint-plugin-jsdoc": "^63.0.2",
    "lefthook": "^2.1.9",
    "markdownlint-cli2": "^0.22.1",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@11.2.2"
}
